# Example configuration file for OCT Pipeline Workflow
# Copy this file to config.yaml and update with your settings

processing:
  surface_method: "find"  # "find", constant value, or path to surface file
  depth: 80  # Depth below surface for enface window
  overlap: 50  # Overlap between tiles in pixels
  mask_threshold: 55  # Threshold for AIP mask creation

paths:
  data_root: "/path/to/data"  # Root path to data directory
  output_base: "/path/to/output"  # Base path for output files
  compressed_base: "/path/to/compressed"  # Separate directory/disk for compressed files
  cloud_upload_path: "s3://bucket/path"  # Base path for cloud uploads

resources:
  tile_processing_workers: 16  # Number of workers for tile processing
  stitching_workers: 4  # Number of workers for stitching
  registration_workers: 2  # Number of workers for registration

cloud:
  provider: "s3"  # Cloud provider: "s3", "gcs", or "azure"
  bucket: "oct-data"  # Cloud bucket name
  region: "us-east-1"  # Cloud region
  upload:
    max_concurrent: 5  # Maximum concurrent uploads
    cli_tool: "aws"  # CLI tool for uploads: "aws", "gsutil", or "azcopy"
    cli_base_args: ["s3", "cp"]  # Base arguments for CLI tool
    # For AWS: ["s3", "cp"]
    # For GCS: ["cp"]
    # For Azure: ["copy"]

slack:
  enabled: false  # Enable Slack notifications
  webhook_url: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"  # For webhook method
  bot_token: "xoxb-your-bot-token"  # For bot API method
  channel: "#oct-processing"  # Slack channel for notifications
  milestones:
    - 0.25  # 25% completion
    - 0.50  # 50% completion
    - 0.75  # 75% completion
    - 1.0   # 100% completion
  send_stitched_images: true  # Send stitched images to Slack

